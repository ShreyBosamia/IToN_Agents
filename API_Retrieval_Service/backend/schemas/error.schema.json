{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/error.schema.json",
  "title": "ApiError",
  "type": "object",
  "additionalProperties": false,
  "required": ["error"],
  "properties": {
    "error": {
      "type": "string",
      "description": "Human-readable error message."
    },
    "errors": {
      "type": "array",
      "description": "Optional field-level validation errors.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "message"],
        "properties": {
          "field": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "examples": [
    {
      "error": "Invalid pipeline request.",
      "errors": [{ "field": "category", "message": "category is required." }]
    },
    {
      "error": "Invalid pipeline request.",
      "errors": [{ "field": "perQuery", "message": "perQuery must be an integer from 1 to 20." }]
    },
    { "error": "Job not found" }
  ]
}
