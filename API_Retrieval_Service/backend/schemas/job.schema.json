{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/job.schema.json",
  "title": "PipelineJob",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "createdAt", "inputs", "startedAt", "finishedAt", "output", "error"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Job identifier generated by server (timestamp-random hex)."
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "done", "error"],
      "description": "Job status."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["city", "state", "category"],
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" },
        "category": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*(?:_[A-Z0-9]+)*$"
        },
        "perQuery": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Optional number of search results requested per generated query."
        },
        "maxUrls": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional maximum number of unique URLs to scrape."
        }
      }
    },
    "startedAt": {
      "description": "ISO timestamp when job started; null until running.",
      "anyOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }]
    },
    "finishedAt": {
      "description": "ISO timestamp when job finished; null until done/error.",
      "anyOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }]
    },
    "output": {
      "description": "Pipeline output. Null until done. When done, matches PipelineRunResult from runPipeline.ts.",
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["output", "outputFile", "sanityFile"],
          "properties": {
            "output": { "$ref": "#/$defs/PipelineOutput" },
            "outputFile": { "type": "string" },
            "sanityFile": { "type": "string" }
          }
        }
      ]
    },
    "error": {
      "description": "Populated only when status=error.",
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["message"],
          "properties": {
            "message": { "type": "string" },
            "stack": { "type": ["string", "null"] }
          }
        }
      ]
    }
  },
  "$defs": {
    "PipelineOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "city",
        "state",
        "category",
        "generated_at",
        "query_file",
        "queries",
        "search",
        "urls",
        "scraped",
        "sanity",
        "sanity_file",
        "extracted"
      ],
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" },
        "category": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "query_file": { "type": "string" },
        "queries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "search": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["query", "urls"],
            "properties": {
              "query": { "type": "string" },
              "urls": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "urls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scraped": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "result"],
            "properties": {
              "url": { "type": "string" },
              "result": {
                "description": "Raw scrape result; structure varies by site/tool.",
                "type": ["object", "array", "string", "number", "boolean", "null"]
              }
            }
          }
        },
        "sanity": {
          "type": "array",
          "items": { "$ref": "#/$defs/SanityDoc" }
        },
        "sanity_file": { "type": "string" },
        "extracted": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url", "result", "method"],
            "properties": {
              "url": { "type": "string" },
              "result": { "$ref": "#/$defs/SanityDoc" },
              "method": { "type": "string", "enum": ["agent", "fallback"] }
            }
          }
        }
      }
    },
    "SanityDoc": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "address",
        "location",
        "serviceTypes",
        "hoursOfOperation",
        "contact"
      ],
      "properties": {
        "name": { "type": "string" },
        "description": {
          "type": "array",
          "items": { "$ref": "#/$defs/SanityBlock" }
        },
        "address": { "type": "string" },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["latitude", "longitude"],
          "properties": {
            "latitude": { "type": ["number", "null"] },
            "longitude": { "type": ["number", "null"] }
          }
        },
        "serviceTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["_id"],
            "properties": { "_id": { "type": "string" } }
          }
        },
        "hoursOfOperation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["periods", "weekdayText"],
          "properties": {
            "periods": {
              "type": "array",
              "items": { "$ref": "#/$defs/HoursPeriod" }
            },
            "weekdayText": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "contact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["phone", "email", "website"],
          "properties": {
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "website": { "type": "string" }
          }
        }
      }
    },
    "SanityBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["_type", "children", "markDefs", "style"],
      "properties": {
        "_type": { "const": "block" },
        "children": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["_type", "text"],
            "properties": {
              "_type": { "const": "span" },
              "text": { "type": "string" }
            }
          }
        },
        "markDefs": {
          "type": "array",
          "items": {},
          "description": "Empty array in current implementation."
        },
        "style": { "const": "normal" }
      }
    },
    "HoursPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open", "close"],
      "properties": {
        "open": {
          "type": "object",
          "additionalProperties": false,
          "required": ["day", "time"],
          "properties": {
            "day": { "type": "integer", "minimum": 1, "maximum": 7 },
            "time": { "type": "string" }
          }
        },
        "close": {
          "type": "object",
          "additionalProperties": false,
          "required": ["day", "time"],
          "properties": {
            "day": { "type": "integer", "minimum": 1, "maximum": 7 },
            "time": { "type": "string" }
          }
        }
      }
    }
  },
  "examples": [
    {
      "id": "1709328475123-a3f29b1c",
      "status": "done",
      "createdAt": "2026-03-01T21:30:15.123Z",
      "inputs": {
        "city": "Austin",
        "state": "TX",
        "category": "FOOD_BANK",
        "perQuery": 5,
        "maxUrls": 20
      },
      "startedAt": "2026-03-01T21:30:17.890Z",
      "finishedAt": "2026-03-01T21:31:02.554Z",
      "output": {
        "output": {
          "city": "Austin",
          "state": "TX",
          "category": "FOOD_BANK",
          "generated_at": "2026-03-01T21:31:02.100Z",
          "query_file": "outputs/Austin_FOOD_BANK_queries.json",
          "queries": ["Austin TX food bank site:.org", "free groceries Austin TX"],
          "search": [{ "query": "Austin TX food bank site:.org", "urls": ["https://example.com"] }],
          "urls": ["https://example.com"],
          "scraped": [{ "url": "https://example.com", "result": { "data": { "text": "..." } } }],
          "sanity": [],
          "sanity_file": "outputs/Austin_FOOD_BANK_sanity.json",
          "extracted": []
        },
        "outputFile": "outputs/Austin_FOOD_BANK_pipeline.json",
        "sanityFile": "outputs/Austin_FOOD_BANK_sanity.json"
      },
      "error": null
    }
  ]
}
