{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/post-pipelines.schema.json",
  "title": "PostPipelinesRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["city", "state", "category"],
  "properties": {
    "city": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^(?!.*\\.\\.)[^<>:\"/\\\\|?*\\u0000-\\u001F]+$",
      "description": "City name used by the pipeline and output filenames."
    },
    "state": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^(?!.*\\.\\.)[^<>:\"/\\\\|?*\\u0000-\\u001F]+$",
      "description": "State/region code or name used by the pipeline."
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9]*(?:_[A-Z0-9]+)*$",
      "description": "Pipeline category in UPPER_SNAKE_CASE, such as FOOD_BANK or SHELTER."
    },
    "perQuery": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "description": "Optional number of Brave Search results to request per generated query."
    },
    "maxUrls": {
      "type": "integer",
      "minimum": 1,
      "description": "Optional maximum number of unique URLs for the pipeline to scrape."
    }
  },
  "examples": [
    {
      "city": "Salem",
      "state": "OR",
      "category": "FOOD_BANK",
      "perQuery": 3,
      "maxUrls": 10
    },
    {
      "city": "Portland",
      "state": "OR",
      "category": "SHELTER"
    }
  ]
}
